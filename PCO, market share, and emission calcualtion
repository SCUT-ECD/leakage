# 获取分类函数
def get_category(powertrain):
    if powertrain in traditional_vehicles:
        return '传统车型'
    if powertrain in electric_vehicles:
        return '电动车型'
    if powertrain in hybrid_vehicles:
        return '混动车型'
    if powertrain in low_carbon_vehicles:
        return '低碳车型'
    return '其他'

# 效用/概率计算
def calculate_utility(segment, adjustment_factors_df, betas, tco_col, powertrain_col, A_factors_df):
    segment['Category'] = segment[powertrain_col].apply(get_category)
    owner_id = segment['Owner'].iloc[0]
    segment['Adjustment_Factor'] = segment.apply(
        lambda row: adjustment_factors_df.loc[
            (adjustment_factors_df['Owner'] == owner_id) & (adjustment_factors_df['Category'] == row['Category']),
            'Adjustment_Factor'
        ].values[0], axis=1
    )
    segment['Best_Ci'] = A_factors_df['Best_Ci'].iloc[segment.index].values
    segment['Utility'] = (segment[tco_col] + segment['Best_Ci'] + segment['Adjustment_Factor']) * segment[powertrain_col].map(betas) * 1e-5
    exp_utility = np.exp(segment['Utility'])
    exputility_sum=exp_utility.sum()
    #print(f" exputility_sum { exputility_sum}")
    segment['Probability'] = exp_utility / exp_utility.sum()
    return exputility_sum,segment[[powertrain_col, tco_col, 'Probability', 'Utility', 'Adjustment_Factor', 'Best_Ci']]

